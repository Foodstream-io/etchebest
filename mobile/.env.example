# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:8081/api
EXPO_PUBLIC_API_TIMEOUT=10000

# Auth Storage Keys
EXPO_PUBLIC_TOKEN_KEY=auth_token
EXPO_PUBLIC_USER_KEY=auth_user

# Google OAuth
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Optional (Web only): must exactly match an authorized redirect URI in Google Cloud.
EXPO_PUBLIC_GOOGLE_REDIRECT_URI=
